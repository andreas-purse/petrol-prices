# Turso database (or file:local.db for local dev)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Ingestion API key (protect the POST /api/ingest endpoint)
INGEST_API_KEY=change-me-to-a-random-secret

# Map tile style URL (OpenStreetMap raster tiles by default)
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Clerk auth (optional — app works without these, auth features just won't appear)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe payments (optional — Pro features hidden without these)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Vercel cron secret (auto-set by Vercel)
CRON_SECRET=your-cron-secret

# Open Charge Map API key (free — register at openchargemap.org)
OCM_API_KEY=your-ocm-api-key

# DVLA Vehicle Enquiry API key (free — register at developer-portal.driver-vehicle-licensing.api.gov.uk)
DVLA_API_KEY=your-dvla-api-key
